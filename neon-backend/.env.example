# Server port
PORT=4000

# JWT secret (auto-generated if not set, but MUST be set in production)
JWT_SECRET=your-secret-key-here

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4000,http://localhost:9621

# Environment
NODE_ENV=development

# Bootstrap secret for making first user admin
BOOTSTRAP_SECRET=make-me-admin

# Seed secret for populating default navigation tabs
SEED_SECRET=seed-default-data
