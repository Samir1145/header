# SQLite backend URL (Express server on port 4000)
VITE_API_URL=http://localhost:4000

# LightRAG AI backend URL (port 9621)
VITE_BACKEND_URL=http://localhost:9621

# Optional: Additional LightRAG servers
# VITE_BACKEND_URL_2=http://localhost:9622
# VITE_BACKEND_URL_3=http://localhost:9623

# Optional: Server token authentication (for LightRAG servers that require auth)
# VITE_SERVER_1_URL=http://localhost:9621
# VITE_SERVER_1_TOKEN=your-token-here

# Optional: Wren chat integration
# VITE_WREN_API_URL=https://your-wren-api-url
# VITE_WREN_API_KEY=your-wren-api-key
# VITE_WREN_USE_PROXY=false

# Optional: Neon search integration
# VITE_NEON_API_URL=https://your-neon-api-url
